    "components": {
        "schemas": {
            "Book": {
                "required": [
                    "title",
                    "author",
                    "summary",
                    "isbn"
                ],
                "properties": {
                    "title": {
                        "type": "string",
                        "example": "1984"
                    },
                    "author": {
                        "type": "string",
                        "example": "GEORGE ORWELL"
                    },
                    "summary": {
                        "type": "string",
                        "example": "Roman dystopique..."
                    },
                    "isbn": {
                        "type": "string",
                        "example": "9780451524935"
                    },
                    "_links": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "BookInput": {
                "required": [
                    "title",
                    "author",
                    "summary",
                    "isbn"
                ],
                "properties": {
                    "title": {
                        "type": "string",
                        "example": "Nouveau livre"
                    },
                    "author": {
                        "type": "string",
                        "example": "Nouvel auteur"
                    },
                    "summary": {
                        "type": "string",
                        "example": "Un resume assez long pour la validation."
                    },
                    "isbn": {
                        "type": "string",
                        "example": "9781234567890"
                    }
                },
                "type": "object"
            },
            "AuthResponse": {
                "properties": {
                    "token": {
                        "type": "string"
                    },
                    "user": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "ErrorResponse": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Invalid credentials"
                    }
                },
                "type": "object"
            },
            "ValidationError": {
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The given data was invalid."
                    },
                    "errors": {
                        "type": "object",
                        "example": {
                            "email": [
                                "The email field is required."
                            ]
                        }
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Authentication endpoints"
        },
        {
            "name": "Books",
            "description": "Book endpoints"
        }
    ]
